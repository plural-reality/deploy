#!/usr/bin/env bash
# deploy/bin/status — check whether deployed nodes match current HEAD.
#
# If configurationRevision matches local HEAD, all flake inputs (and thus
# the entire closure) are guaranteed identical — no per-input check needed.
#
# Data flow:
#   git rev-parse HEAD          → expected deploy rev
#   nix eval .#meta.nodes       → { node: { domain } }
#   curl /.well-known/version   → { configurationRevision, inputs, ... }
#
# Exit code: number of out-of-date nodes.

set -euo pipefail

FLAKE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

expected=$(git -C "$FLAKE_ROOT" rev-parse HEAD)

nodes=$(nix eval "$FLAKE_ROOT#meta.nodes" --json 2>/dev/null)

drift=0

echo "$nodes" | jq -r 'to_entries[] | "\(.key)\t\(.value.domain)"' |
while IFS=$'\t' read -r node domain; do
  version_json=$(curl -sf --max-time 5 "https://${domain}/.well-known/version" 2>/dev/null) || version_json=""

  if [ -z "$version_json" ]; then
    printf '%s (%s): expected=%s actual=unreachable ❌\n' "$node" "$domain" "${expected:0:12}"
    drift=$((drift + 1))
  else
    actual=$(echo "$version_json" | jq -r '.configurationRevision')
    short_expected="${expected:0:12}"
    short_actual="${actual:0:12}"

    if [ "$expected" = "$actual" ]; then
      printf '%s: %s ✅\n' "$node" "$short_expected"
    else
      printf '%s (%s): expected=%s actual=%s ❌\n' "$node" "$domain" "$short_expected" "$short_actual"
      drift=$((drift + 1))
    fi
  fi
done

exit "$drift"
